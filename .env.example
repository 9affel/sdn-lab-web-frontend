# SDN-EDR Dashboard Environment Configuration

# ── API Base URL ──
# FastAPI backend address. Set this to the WSL-hosted FastAPI endpoint.
VITE_API_BASE_URL=http://172.20.20.8:8000

# ── Application Settings ──
VITE_APP_NAME=SDN-EDR Dashboard
VITE_APP_VERSION=1.0.0

# ── Request Timeouts (ms) ──
VITE_REQUEST_TIMEOUT=10000

# ── Polling Intervals (ms) ──
VITE_STATUS_POLL_INTERVAL=5000
VITE_LOGS_POLL_INTERVAL=10000
