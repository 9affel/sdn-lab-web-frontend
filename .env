# Backend FastAPI is accessible at localhost:8000 from Windows.
# WSL mirrored networking is enabled in ~/.wslconfig — localhost always works.
VITE_API_BASE_URL=http://localhost:8000

# Application Settings
VITE_APP_NAME=SDN-EDR Dashboard
VITE_APP_VERSION=1.0.0

# Request Timeouts (ms)
VITE_REQUEST_TIMEOUT=10000

# Polling Intervals (ms) — matches Ryu's 5s telemetry push cycle
VITE_STATUS_POLL_INTERVAL=5000
VITE_LOGS_POLL_INTERVAL=10000
